    timeLimit: 15
    hasDistraction: 1
    distractionMessage: "\u0110\u1ED5 l\u1ED7i cho kh\xE1ch h\xE0ng ngay!"
  - victimMessage: "Tr\u1EDDi \u01A1i c\u1EE9u ch\u1ECB v\u1EDBi, gi\u1EDD l\xE0m
