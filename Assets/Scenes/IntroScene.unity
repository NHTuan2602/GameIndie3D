MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1758569493}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2510c35475ee80a44b762305a8b920f9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  dialoguePanel: {fileID: 1398441839}
  nameText: {fileID: 1127978853}
  dialogueText: {fileID: 639867130}
  choicePanel: {fileID: 754223984}
  agreeButton: {fileID: 2076010900}
  refuseButton: {fileID: 927441759}
  endingPanel: {fileID: 1114060199}
  endingText: {fileID: 2030420840}
  nextSceneName: MainGameScene
  typingSpeed: 0.05
  introLines:
  - speakerName: '[PLAYER]'
    sentence: "L\u1EA1i m\u1ED9t tin nh\u1EAFn gi\u1EE5c \u0111\xF3ng vi\u1EC7n ph\xED
      n\u1EEFa... M\u1EB9 n\u1EB1m h\xF4n m\xEA trong \u0111\xF3 \u0111\xE3 2 n\u0103m
      r\u1ED3i."
  - speakerName: '[PLAYER]'
    sentence: "C\u1EE9 c\xE0y ca \u0111\xEAm \u1EDF c\xE1i si\xEAu th\u1ECB n\xE0y
      th\xEC \u0111\u1EBFn bao gi\u1EDD m\u1EDBi \u0111\u1EE7 ti\u1EC1n tr\u1EA3
      n\u1EE3 cho \xF4ng gi\xE0 c\u1EDD b\u1EA1c kh\u1ED1n n\u1EA1n kia, n\xF3i g\xEC
      \u0111\u1EBFn ti\u1EC1n gi\u1EEF \u1ED1ng th\u1EDF cho m\u1EB9..."
  - speakerName: '[PLAYER]'
    sentence: "L\u1EA1ng qu\u1EA1ng kh\xF4ng tr\u1EA3 t\u1EE5i giang h\u1ED3 n\xF3
      t\u1EDBi si\u1EBFc c\xE1i nh\xE0 m\u1EA5t "
  - speakerName: '[PLAYER]'
    sentence: "Th\xF4i c\u1EE9 ti\u1EBFp t\u1EE5c c\xF4ng vi\u1EC7c \u0111\xE3 "
  - speakerName: "H\u01B0\u1EDBng d\u1EABn"
    sentence: "B\u1EAFt \u0111\u1EA7u v\u1EDBi vi\u1EC7c x\u1EBFp \u0111\xFAng c\xE1c
      \u0111\u1ED3 v\u1EADt d\u01B0\u1EDBi m\u1EB7t \u0111\u1EA5t l\xEAn k\u1EC7 "
  outroLines:
  - speakerName: "V\u0169"
    sentence: "\xCA, n\xE3y tao v\xF4 t\xECnh th\u1EA5y tin nh\u1EAFn b\u1EC7nh vi\u1EC7n
      c\u1EE7a m\xE0y. V\u1EABn k\u1EB9t ti\u1EC1n \xE0?"
  - speakerName: '[PLAYER]'
    sentence: "K\u1EB9t c\u1EE9ng ng\u1EAFc. B\xE1c s\u0129 b\u1EA3o kh\xF4ng n\u1ED9p
      th\xEAm 15 tri\u1EC7u trong tu\u1EA7n n\xE0y th\xEC h\u1ECD \u0111\xE0nh d\u1EEBng
      thu\u1ED1c."
  - speakerName: "V\u0169"
    sentence: "Nghe n\xE0y, b\xEAn c\xF4ng ty m\xE1y t\xEDnh tao \u0111ang thi\u1EBFu
      ng\u01B0\u1EDDi. M\xE0y g\u1EADt \u0111\u1EA7u \u0111i theo tao t\u1ED1i nay,
      gi\xE1m \u0111\u1ED1c s\u1EBD ban \u01A1n b\u1EAFn th\u1EB3ng 30 tri\u1EC7u
      ti\u1EC1n \u1EE9ng tr\u01B0\u1EDBc v\xE0o t\xE0i kho\u1EA3n b\u1EC7nh vi\u1EC7n
      cho m\u1EB9 m\xE0y ngay l\u1EADp t\u1EE9c. C\u1EE9 lo cho b\xE1c tr\u01B0\u1EDBc
      \u0111\xE3"
  - speakerName: '[PLAYER]'
    sentence: "Tin chu\u1EA9n ch\u01B0a anh"
  - speakerName: "V\u0169"
    sentence: "Qua bi\xEAn gi\u1EDBi l\xE0m d\u1EF1 \xE1n k\xEDn. U\u1ED1ng chai
      n\u01B0\u1EDBc n\xE0y cho t\u1EC9nh r\u1ED3i l\xEAn xe \u0111i, xe c\xF4ng
      ty \u0111\u1ED7 ngo\xE0i kia k\xECa. Nhanh, kh\xF4ng ng\u01B0\u1EDDi kh\xE1c
      tranh m\u1EA5t slot b\xE2y gi\u1EDD!"
