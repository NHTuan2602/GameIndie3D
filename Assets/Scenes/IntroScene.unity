  dialogueLines:
  - speakerName: "B\u1EA1n c\u0169"
    sentence: "\xCA [PLAYER], d\u1EA1o n\xE0y l\xE0m si\xEAu th\u1ECB c\u1EF1c kh\xF4ng?
      Tao c\xF3 m\u1ED1i l\xE0m vi\u1EC7c v\u0103n ph\xF2ng ngon l\u1EAFm"
  - speakerName: '[PLAYER]'
    sentence: "Vi\u1EC7c g\xEC th\u1EBF m\xE0y? L\u01B0\u01A1ng l\u1EADu th\u1EBF
      n\xE0o?"
  - speakerName: "B\u1EA1n c\u0169"
    sentence: "B\xEAn n\u01B0\u1EDBc ngo\xE0i, bao \u0103n \u1EDF \u0111i l\u1EA1i.
      G\u1EADt \u0111\u1EA7u c\xE1i t\u1ED1i nay c\xF3 xe \u0111\xF3n lu\xF4n. \u0110i
      kh\xF4ng?"
