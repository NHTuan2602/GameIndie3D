  m_Name: Victim_06_C Hoa 50 tui
  m_EditorClassIdentifier: Assembly-CSharp::VictimProfile
  victimName: "C\xF4 Hoa (50 tu\u1ED5i)"
  jobOrAge: "Qu\xE0 t\u1EB7ng t\u1EEB \"B\u1EA1n trai T\xE2y\""
  avatar: {fileID: 0}
  isTroll: 0
