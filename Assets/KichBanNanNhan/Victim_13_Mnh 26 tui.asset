    scriptToType: Da ben em dang dua xe len xe tai cho xuong cho anh.
    timeLimit: 15
    hasDistraction: 1
    distractionMessage: "10 c\u1EE7 ngon \u01A1! L\xE0m t\u1ED1t l\u1EAFm!"
